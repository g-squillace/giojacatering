    "graphql": "^16.8.1",
    "gsap": "^3.12.5",
    "mapbox-gl": "^3.6.0",
    "next": "^14.0.3",
    "openai": "^4.23.0",
    "react": "^18",
    "react-datocms": "^6.0.1",
    "react-dom": "^18",
    "react-hook-form": "^7.51.0",
